# ── Zendesk / Scraper ────────────────────────────
ZENDESK_LOCALE=en-us
# Optional: max number of articles to scrape (default: 30)
SCRAPE_LIMIT=30

# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=your-api-key
# Optional: vector store name on first creation (default: optisigns-support-docs)
VECTOR_STORE_NAME=optibot
# Optional: model used by ask.py (default: gpt-5.6)
OPENAI_MODEL=gpt-5.6
